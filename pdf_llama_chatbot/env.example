# PDF directory (relative to project root)
PDF_DIR=pdfs

# Vector store persistence directory
VECTOR_STORE_DIR=vector_store

# ---------- Choose one: Ollama or Hugging Face ----------
# Set to true when using Ollama; ensure Ollama is installed and running (e.g. ollama run llama2)
USE_OLLAMA=true
OLLAMA_MODEL=llama2
OLLAMA_BASE_URL=http://localhost:11434

# Hugging Face model (when USE_OLLAMA=false): HF model id or local path
LLAMA2_MODEL=meta-llama/Llama-2-7b-chat-hf
# Local example: LLAMA2_MODEL=D:/models/Llama-2-7b-chat-hf

# Embedding model: HF model id or local dir (use local path + HF_HUB_OFFLINE=1 when offline)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Offline example: EMBEDDING_MODEL=./models/paraphrase-multilingual-MiniLM-L12-v2
# HF_HUB_OFFLINE=1

# Required when pulling gated models from Hugging Face; leave empty when using Ollama or local model only
HF_TOKEN=your_huggingface_token_here

# Fine-tune output directory
FINETUNE_OUTPUT_DIR=finetuned_llama
FINETUNE_DATA_DIR=finetune_data
